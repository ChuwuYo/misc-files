{
  "name": "eikon",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "fix": "oxlint --fix && biome format --write .",
    "qa": "oxlint && biome format . && svelte-check --tsconfig ./tsconfig.app.json",
    "start": "bash scripts/dev.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@iconify-json/iconamoon": "^1.2.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.3",
    "oxlint": "^1.65.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "~6.0.2",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/oxipng": "^2.3.0",
    "@jsquash/png": "^3.1.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "cropperjs": "^2.1.1",
    "konva": "^10.3.0",
    "pica": "^10.0.0",
    "svelte-awesome-color-picker": "^4.1.2"
  }
}
