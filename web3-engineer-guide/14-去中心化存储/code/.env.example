# 复制为 .env 并填入真实值，禁止提交 .env 到 git
# 各服务申请页面：
#   PINATA_JWT      → https://app.pinata.cloud/developers/api-keys
#   LIGHTHOUSE_API_KEY → https://files.lighthouse.storage/dashboard/apikey
#   PRIVATE_KEY     → 一个有少量 ETH 的测试钱包，用于 Irys 付费

PINATA_JWT=your_pinata_jwt_here
LIGHTHOUSE_API_KEY=your_lighthouse_api_key_here
PRIVATE_KEY=0xYourEthereumPrivateKeyHere

# Walrus 通过 sui CLI 不走 .env，但你需要：
#   1. sui client active-env  → 指向 mainnet 或 testnet
#   2. sui client gas         → 确认有 SUI 和 WAL 余额
