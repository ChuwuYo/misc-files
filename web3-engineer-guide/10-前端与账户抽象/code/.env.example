# NextAuth
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
NEXTAUTH_SECRET=replace_me_with_32_byte_base64_secret

# Reown / WalletConnect (https://cloud.reown.com)
NEXT_PUBLIC_WC_PROJECT_ID=your_reown_project_id

# RPC 提供商（推荐 Alchemy / QuickNode）
NEXT_PUBLIC_RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Pimlico bundler + paymaster (https://dashboard.pimlico.io)
NEXT_PUBLIC_PIMLICO_API_KEY=pim_your_api_key

# 演示用：本项目部署的 BatchExecutor 合约地址（EIP-7702 章节用）
NEXT_PUBLIC_BATCH_EXECUTOR=0x0000000000000000000000000000000000000000
